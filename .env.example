# Banco de dados
DATABASE_URL="postgresql://user:pass@localhost:5432/db"

# JWT — acesso de curta duração
JWT_SECRET="change-me-in-production"
JWT_EXPIRES_IN="15m"

# CORS — separar origens por vírgula (deixar em branco abre para todas)
ALLOWED_ORIGINS="http://localhost:3000,https://meuapp.com"

# URL do frontend (usado no link de recuperação de senha)
FRONTEND_URL="http://localhost:3000"

# Porta do servidor
PORT=3333

# SMTP (opcional — necessário para recuperação de senha em produção)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=sua-api-key-aqui
SMTP_FROM="ERP Dias <noreply@erpdias.com>"
