# Banco de dados
DATABASE_URL="postgresql://user:pass@localhost:5432/db"

# JWT — acesso de curta duração
JWT_SECRET="change-me-in-production"
JWT_EXPIRES_IN="15m"

# CORS — separar origens por vírgula (deixar em branco abre para todas)
ALLOWED_ORIGINS="http://localhost:3000,https://meuapp.com"

# URL do frontend (usado no link de recuperação de senha)
FRONTEND_URL="http://localhost:3000"

# Porta do servidor
PORT=3333

# RabbitMQ — broker de notificações (emails, convites, recuperação de senha)
RABBITMQ_URL="amqp://guest:guest@localhost:5672"

# Chatbot — chave compartilhada com ms-chatbot para endpoints /chatbot/**
INTERNAL_API_KEY="mude-para-uma-chave-segura-com-32-caracteres-min"

# SSO Google
# Passo a passo para obter as credenciais:
#   1. Acesse https://console.cloud.google.com/ e crie (ou selecione) um projeto.
#   2. Em "APIs e serviços" → "Tela de permissão OAuth":
#        - Tipo: "Externo" (ou "Interno" se for Google Workspace da sua empresa)
#        - Preencha nome do app, e-mail de suporte e e-mail do desenvolvedor
#        - Em "Escopos", adicione: .../auth/userinfo.email e .../auth/userinfo.profile
#        - Em "Usuários de teste", inclua os e-mails que vão logar enquanto o app
#          estiver em modo "Em teste".
#   3. Em "APIs e serviços" → "Credenciais" → "Criar credenciais" → "ID do cliente OAuth":
#        - Tipo de aplicativo: "Aplicativo da Web"
#        - "URIs de redirecionamento autorizados": adicione exatamente o valor de
#          GOOGLE_CALLBACK_URL abaixo (ex.: http://localhost:3333/auth/google/callback).
#          Em produção, adicione também https://api.suaempresa.com/auth/google/callback.
#   4. Copie o "ID do cliente" para GOOGLE_CLIENT_ID e a "Chave secreta do cliente"
#      para GOOGLE_CLIENT_SECRET (a chave só aparece uma vez — guarde com segurança).
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_CALLBACK_URL="http://localhost:3333/auth/google/callback"
